{
  "name": "pdf-translator",
  "private": true,
  "version": "1.0.0",
  "description": "PDF 翻译阅读器 - 桌面应用",
  "main": "electron/main.js",
  "scripts": {
    "build": "cd frontend && npx vite build",
    "serve": "cd backend && python3.12 -m uvicorn main:app --host 0.0.0.0 --port 8001",
    "dev": "npm run build && npm run serve",
    "dev-web": "concurrently -n api,web -c blue,green \"npm run serve\" \"cd frontend && npx vite --host\"",
    "electron": "npm run build && electron .",
    "electron-dev": "npm run build && sleep 1 && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist:win": "npm run build && electron-builder --win",
    "dist:win-portable": "npm run build && electron-builder --win portable",
    "dist:mac": "npm run build && electron-builder --mac",
    "start": "npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "electron": "^33.0.0"
  },
  "build": {
    "appId": "com.pdf-translator.app",
    "productName": "PDF翻译阅读器",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/dist",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "frontend/dist",
        "to": "frontend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "shortcutName": "PDF翻译阅读器"
    }
  }
}
